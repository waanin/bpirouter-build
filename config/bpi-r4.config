# ── 1. Target Hardware Platform (BPI-R4) ──
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_bananapi_bpi-r4=y

# ── 2. Core Web Service (Nginx as uhttpd replacement) ──
CONFIG_PACKAGE_nginx-ssl=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-mod-admin-full=y

# ── 3. Full Wi-Fi 7 Driver and Crypto Engine ──
CONFIG_PACKAGE_kmod-mt7996e=y
CONFIG_PACKAGE_mt7996-firmware=y
# CONFIG_PACKAGE_wpad-mbedtls is not set
CONFIG_PACKAGE_wpad-openssl=y
# Must explicitly disable the basic wpad variant to avoid conflicts
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set

# ── 4. Hardware Acceleration (Maximize MT7988A performance) ──
CONFIG_PACKAGE_kmod-nft-offload=y

# ── 5. Enterprise VPN Suite ──
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_openvpn-openssl=y
CONFIG_PACKAGE_luci-app-openvpn=y

# ── 6. Multi-WAN Load Balancing and Failover ──
CONFIG_PACKAGE_mwan3=y
CONFIG_PACKAGE_luci-app-mwan3=y

# ── 7. 5G Cellular Network Expansion (for M.2 interface) ──
CONFIG_PACKAGE_uqmi=y
CONFIG_PACKAGE_umbim=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_usb-modeswitch=y

# ── 8. High-speed Storage and Docker Preparation (for NVMe and USB3.0) ──
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-nvme=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y

# ── 9. SQM Smart Queue Management (Essential for High-end Routers) ──
CONFIG_PACKAGE_sqm-scripts=y
CONFIG_PACKAGE_luci-app-sqm=y

# ── 10. System Debugging and Common Tools ──
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_uboot-envtools=y

CONFIG_PACKAGE_kmod-sfp=y
CONFIG_PACKAGE_kmod-phy-aquantia=y

CONFIG_PACKAGE_kmod-pwm-mediatek=y
CONFIG_PACKAGE_kmod-hwmon-pwmfan=y
CONFIG_PACKAGE_lm-sensors=y

CONFIG_PACKAGE_i2c-tools=y

CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_mtr=y
CONFIG_PACKAGE_ip-full=y

CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_pciutils=y
CONFIG_PACKAGE_util-linux-lsblk=y
CONFIG_PACKAGE_iwinfo=y

CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_parted=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_dosfstools=y
CONFIG_PACKAGE_sysfsutils=y
